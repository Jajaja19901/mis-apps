# Artefactos generados para entrega (no versionar)
10-agentes.zip
*.zip

# Dependencias de prueba del verificador (no entran al repo)
node_modules/
package.json
package-lock.json

# Scripts temporales de prueba/medición (verificación manual y revisores).
# Los scripts REALES del proyecto viven en tools/ ; estos patrones solo afectan a la raíz.
/*.mjs
/_*.js
/*.tmp.*
/axe-audit*.mjs
/measure.mjs

# Estado en disco del servidor de sincronización (se genera al vuelo; no versionar)
apps/mh-collective-datos.json
apps/.mh-collective-datos.tmp-*

# Build de Netlify: se genera al desplegar con `cp apps/mh-collective-fiesta.html web/index.html`.
# No lo versionamos para no dejar una copia vieja que se desincronice de la app real.
web/index.html
