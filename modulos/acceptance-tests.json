[
  {
    "name": "Onboarding: 3 pasos completos (modo → fuente → línea) y se cierra",
    "steps": [
      { "expectVisible": "#ui-pasoModo" },
      { "click": "#ui-modoSuper" },
      { "expectVisible": "#ui-fuenteSaltar" },
      { "click": "#ui-fuenteSaltar" },
      { "expectVisible": "#ui-dibujarLinea" },
      { "click": "#ui-onboardingTerminar" },
      { "expectGone": "#ui-pasoModo" }
    ]
  },
  {
    "name": "PIN: crear PIN de 4 dígitos y abrir el panel de ajustes",
    "steps": [
      { "click": "#ui-modoSuper" },
      { "click": "#ui-fuenteSaltar" },
      { "click": "#ui-onboardingTerminar" },
      { "click": "#ui-btnAjustes" },
      { "wait": 400 },
      { "fill": { "sel": "#cfg-pinNuevo1", "value": "1234" } },
      { "fill": { "sel": "#cfg-pinNuevo2", "value": "1234" } },
      { "clickText": "Crear PIN" },
      { "wait": 500 },
      { "expectVisible": "#ui-btnCerrarAjustes" },
      { "expect": "Fuente de vídeo" }
    ]
  },
  {
    "name": "Pantalla pública de aforo: se abre con PASE y se cierra al tocar",
    "steps": [
      { "click": "#ui-modoSuper" },
      { "click": "#ui-fuenteSaltar" },
      { "click": "#ui-onboardingTerminar" },
      { "click": "#ui-btnAforo" },
      { "expectVisible": "#ui-aforoNumero" },
      { "expect": "PASE" },
      { "click": "#ui-aforo" },
      { "expectGone": "#ui-aforoNumero" }
    ]
  },
  {
    "name": "Alerta crítica de prueba: flash a pantalla completa, cierre y registro en el feed",
    "steps": [
      { "click": "#ui-modoSuper" },
      { "click": "#ui-fuenteSaltar" },
      { "click": "#ui-onboardingTerminar" },
      { "click": "#cfg-btnProbar-critico" },
      { "wait": 400 },
      { "expectVisible": "#alerta-btnCerrar" },
      { "click": "#alerta-btnCerrar" },
      { "expectGone": "#alerta-btnCerrar" },
      { "expect": "Alerta de prueba" }
    ]
  },
  {
    "name": "Zonas: la toolbar de dibujo responde sin vídeo (línea → cancelar)",
    "steps": [
      { "click": "#ui-modoSuper" },
      { "click": "#ui-fuenteSaltar" },
      { "click": "#ui-onboardingTerminar" },
      { "click": "#zona-linea" },
      { "expectVisible": "#zona-ayuda" },
      { "expectVisible": "#zona-cancelar" },
      { "click": "#zona-cancelar" },
      { "expectGone": "#zona-ayuda" }
    ]
  },
  {
    "name": "Modo carretera: panel de vehículos/plazas visible y aviso de velocidad honesto",
    "steps": [
      { "click": "#ui-modoCarretera" },
      { "click": "#ui-fuenteSaltar" },
      { "click": "#ui-onboardingTerminar" },
      { "wait": 300 },
      { "expectVisible": "#car-plazas" },
      { "expectVisible": "#zona-plaza" },
      { "expect": "no válida como medición legal" }
    ]
  }
]
