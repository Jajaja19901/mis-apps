{
  "name": "superpowers-simulation",
  "version": "1.0",
  "description": "Plan, code with tests, and self-review — mimics superpowers functionality for web/remote environments",
  "author": "Claude Code Web Optimization",
  "categories": ["development", "planning", "testing"],
  "tags": ["tdd", "planning", "review"],
  "commands": {
    "plan-and-code": {
      "description": "Plan a feature, write tests, then implement",
      "trigger": "Plan feature: [description]",
      "workflow": [
        "1. Analyze requirements and edge cases",
        "2. Write failing tests first (TDD)",
        "3. Implement solution",
        "4. Self-review code for quality",
        "5. Run tests and verify"
      ]
    },
    "smart-review": {
      "description": "Deep code review before implementation",
      "trigger": "/smart-review",
      "workflow": [
        "Check for bugs and design issues",
        "Suggest simplifications and optimizations",
        "Review security and performance",
        "Verify tests cover edge cases"
      ]
    }
  },
  "environment": ["web", "remote", "cli"],
  "permissions": ["read-files", "write-files", "execute-tests"]
}
