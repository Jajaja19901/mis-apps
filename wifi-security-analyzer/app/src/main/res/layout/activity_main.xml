<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/disclaimer"
            android:textSize="12sp"
            android:paddingBottom="12dp" />

        <!-- Datos de empresa -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/company_label"
            android:textStyle="bold"
            android:paddingTop="8dp" />

        <EditText
            android:id="@+id/etCompany"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/company_hint"
            android:inputType="text" />

        <Button
            android:id="@+id/btnSaveCompany"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/save" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33888888"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- 1. Escaneo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_scan"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/scan_networks" />

        <TextView
            android:id="@+id/outScan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingTop="6dp"
            android:text="@string/press_scan" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33888888"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- 2. Auditor de contrasena -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_password"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/password_help"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/password_hint"
            android:inputType="textVisiblePassword" />

        <Button
            android:id="@+id/btnAudit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/audit_password" />

        <TextView
            android:id="@+id/outPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingTop="6dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33888888"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- 3. Router -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_router"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/router_help"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnRouter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_router" />

        <TextView
            android:id="@+id/outRouter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingTop="6dp"
            android:paddingBottom="24dp" />

    </LinearLayout>

</ScrollView>
