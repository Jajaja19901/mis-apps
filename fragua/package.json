{
  "name": "fragua",
  "productName": "Fragua",
  "version": "1.0.0",
  "description": "Asistente profesional de programación con IA 100% offline: chat, editor, terminal, indexación semántica y refactorización sobre modelos locales.",
  "author": "Incuba tu Negocio · Jaime M. M.",
  "license": "MIT",
  "main": "dist/main/main/main.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder --config electron-builder.yml"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "monaco-editor": "^0.52.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
